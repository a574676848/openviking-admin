DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASS=your_password_here
DB_NAME=openviking_admin

JWT_SECRET=your_jwt_secret_here_min_32_chars
ENCRYPTION_KEY=your_32_char_encryption_key_here

OV_BASE_URL=http://localhost:1933
OV_API_KEY=your_ov_api_key_here
OV_ACCOUNT=default

FRONTEND_URL=http://localhost:6002
PORT=6001
NODE_ENV=development

# capability rate limit store
CAPABILITY_RATE_LIMIT_STORE_DRIVER=memory
CAPABILITY_RATE_LIMIT_REDIS_URL=redis://localhost:6379/0
CAPABILITY_RATE_LIMIT_REDIS_HOST=127.0.0.1
CAPABILITY_RATE_LIMIT_REDIS_PORT=6379
CAPABILITY_RATE_LIMIT_REDIS_DB=0
CAPABILITY_RATE_LIMIT_REDIS_PASSWORD=
CAPABILITY_RATE_LIMIT_REDIS_TLS=false
CAPABILITY_RATE_LIMIT_REDIS_KEY_PREFIX=openviking:capability-rate-limit
CAPABILITY_RATE_LIMIT_REDIS_CONNECT_TIMEOUT_MS=1500
