{
  "name": "@openviking-admin/ova-cli",
  "version": "0.1.3",
  "description": "OpenViking Admin capability-first CLI",
  "keywords": [
    "openviking",
    "cli",
    "capability-platform",
    "agent-tools"
  ],
  "homepage": "https://github.com/openviking/openviking-knowdge",
  "repository": {
    "type": "git",
    "url": "https://github.com/openviking/openviking-knowdge.git",
    "directory": "packages/ova-cli"
  },
  "bugs": {
    "url": "https://github.com/openviking/openviking-knowdge/issues"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "ova": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "assets"
  ],
  "scripts": {
    "clean": "node -e \"const fs=require('fs'); fs.rmSync('dist',{recursive:true,force:true}); for (const file of fs.readdirSync('.')) if (/^openviking-admin-ova-cli-.*\\.tgz$/.test(file)) fs.rmSync(file,{force:true});\"",
    "build": "tsc -p tsconfig.json",
    "dev": "ts-node src/index.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "jest --config jest.config.js",
    "prepack": "npm run clean && npm run build"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^24.0.0",
    "jest": "^30.0.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3"
  }
}
