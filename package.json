{
  "name": "openviking-admin",
  "private": true,
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev": "pnpm --parallel --filter server --filter web run dev",
    "build": "pnpm -r --if-present run build",
    "test": "pnpm -r --if-present run test",
    "lint": "pnpm -r --if-present run lint",
    "format": "pnpm -r --if-present run format",
    "typecheck": "pnpm -r --if-present run typecheck",
    "docs:check": "node scripts/check-doc-links.mjs && node scripts/check-capability-contracts.mjs && node scripts/check-readme-commands.mjs && node scripts/check-api-reference-routes.mjs && node scripts/check-examples-smoke.mjs",
    "env:check": "node scripts/check-env-example.mjs",
    "server:dev": "pnpm --filter server run dev",
    "server:build": "pnpm --filter server run build",
    "server:test": "pnpm --filter server run test",
    "server:lint": "pnpm --filter server run lint",
    "server:migration:run": "pnpm --filter server run migration:run",
    "server:migration:revert": "pnpm --filter server run migration:revert",
    "web:dev": "pnpm --filter web run dev",
    "web:build": "pnpm --filter web run build",
    "web:lint": "pnpm --filter web run lint",
    "web:typecheck": "pnpm --filter web run typecheck",
    "cli:dev": "pnpm --filter @openviking-admin/ova-cli run dev --",
    "cli:build": "pnpm --filter @openviking-admin/ova-cli run build",
    "cli:test": "pnpm --filter @openviking-admin/ova-cli run test",
    "cli:typecheck": "pnpm --filter @openviking-admin/ova-cli run typecheck",
    "ova": "pnpm --filter @openviking-admin/ova-cli run dev --"
  }
}
